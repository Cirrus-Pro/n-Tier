     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SeedRandom", "[", "42", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$TestIterations", "=", "10000"}], ";", "\[IndentingNewLine]", 
