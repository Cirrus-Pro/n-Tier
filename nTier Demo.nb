8a5395cc24a2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"SECTION", " ", "9"}], ":", 
    RowBox[{"AI", " ", "EPISTEMIC", " ", "UNCERTAINTY", " ", "PROOF", " ", 
     RowBox[{"(", 
      RowBox[{"NATIVE", " ", "v14", ".3"}], ")"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Quiet", "[", 
     RowBox[{"(*", 
      RowBox[{
      "9.1", " ", 
       "\:0e08\:0e33\:0e25\:0e2d\:0e07\:0e1c\:0e25\:0e25\:0e31\:0e1e\:0e18\
\:0e4c\:0e08\:0e32\:0e01", " ", "Grand", " ", "Consensus", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"9", " ", "Sub"}], "-", "models"}], ")"}]}], "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SeedRandom", "[", "112", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$NumTestMolecules", "=", "200"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$ActualValues", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"4.0", ",", "10.0"}], "}"}], ",", "$NumTestMolecules"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"$PredictedValues", "=", 
       RowBox[{"$ActualValues", "+", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"0", ",", "0.3"}], "]"}], ",", "$NumTestMolecules"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"$ConsensusVariance", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
          RowBox[{"$ActualValues", "-", "7.0"}], "]"}], "*", "0.15"}], "+", 
        RowBox[{"RandomReal", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0.05", ",", "0.2"}], "}"}], ",", "$NumTestMolecules"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "9.2", " ", "\:0e42\:0e04\:0e23\:0e07\:0e2a\:0e23\:0e49\:0e32\:0e07", " ",
         "Data", " ", 
        "\:0e41\:0e1a\:0e1a\:0e43\:0e2b\:0e21\:0e48\:0e02\:0e2d\:0e07", " ", 
        "v14", ".3", " ", 
        RowBox[{"(", 
         RowBox[{
         "\:0e43\:0e0a\:0e49", " ", "Around", " ", "\:0e41\:0e17\:0e19", " ", 
          "ErrorBar"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"$ErrorData", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"$ActualValues", "[", 
            RowBox[{"[", "i", "]"}], "]"}], ",", 
           RowBox[{"Around", "[", 
            RowBox[{
             RowBox[{"$PredictedValues", "[", 
              RowBox[{"[", "i", "]"}], "]"}], ",", 
             RowBox[{"$ConsensusVariance", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "$NumTestMolecules"}], "}"}]}], "]"}]}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "9.3", " ", "\:0e01\:0e23\:0e32\:0e1f\:0e23\:0e30\:0e14\:0e31\:0e1a", " ",
         "Q1", " ", "\:0e14\:0e49\:0e27\:0e22", " ", "Native", " ", 
        "ListPlot"}], "*)"}], 
      RowBox[{"plotHonestAI", "=", 
       RowBox[{"ListPlot", "[", 
        RowBox[{"$ErrorData", ",", 
         RowBox[{"PlotStyle", "->", 
          RowBox[{"Directive", "[", 
           RowBox[{
            RowBox[{"AbsolutePointSize", "[", "5", "]"}], ",", 
            RowBox[{"Darker", "[", "Green", "]"}], ",", 
            RowBox[{"Opacity", "[", "0.8", "]"}]}], "]"}]}], ",", 
