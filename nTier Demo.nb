Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"SECTION", ":", " ", 
    RowBox[{"MARKOVIAN", " ", "TRANSITION", " ", "MATRIX", " ", 
     RowBox[{"(", "HEATMAP", ")"}]}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Quiet", "[", 
     RowBox[{"(*", 
      RowBox[{
      "1.", " ", "Simulate", " ", "Markov", " ", "Transition", " ", 
       "Probabilities", " ", "for", " ", "15", " ", "Logistics", " ", 
       "Hubs"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"SeedRandom", "[", "999", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$NumNodes", "=", "15"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$MarkovMatrix", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "==", "j"}], ",", "0.0", ",", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"i", "-", "j"}], "]"}], "==", "1"}], "||", 
              RowBox[{
               RowBox[{"Abs", "[", 
                RowBox[{"i", "-", "j"}], "]"}], "==", "3"}], "||", 
              RowBox[{
               RowBox[{"RandomReal", "[", "]"}], ">", "0.85"}]}], ",", 
             RowBox[{"RandomReal", "[", 
              RowBox[{"{", 
               RowBox[{"0.6", ",", "1.0"}], "}"}], "]"}], ",", 
             RowBox[{"RandomReal", "[", 
              RowBox[{"{", 
               RowBox[{"0.0", ",", "0.15"}], "}"}], "]"}]}], "]"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "$NumNodes"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", "$NumNodes"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"$MarkovMatrix", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"#", "/", 
           RowBox[{"Total", "[", "#", "]"}]}], ")"}], "&"}], "/@", 
        "$MarkovMatrix"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "\:0e04\:0e33\:0e19\:0e27\:0e13\:0e04\:0e27\:0e32\:0e21\:0e19\:0e48\
\:0e32\:0e08\:0e30\:0e40\:0e1b\:0e47\:0e19\:0e2a\:0e39\:0e07\:0e2a\:0e38\:0e14\
\:0e40\:0e1e\:0e37\:0e48\:0e2d\:0e19\:0e33\:0e44\:0e1b\:0e08\:0e31\:0e14\:0e23\
\:0e30\:0e40\:0e1a\:0e35\:0e22\:0e1a\:0e2a\:0e40\:0e01\:0e25\:0e02\:0e2d\:0e07\
", " ", "BarLegend"}], "*)"}], 
      RowBox[{"$maxProb", "=", "1"}], " ", 
      RowBox[{"(*", 
       RowBox[{"Max", "[", "$MarkovMatrix", "]"}], "*)"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"2.", " ", "Plotting", " ", "the", " ", "Heatmap"}], "*)"}], 
      RowBox[{"plotMarkovMatrix", "=", 
       RowBox[{"MatrixPlot", "[", 
        RowBox[{"$MarkovMatrix", ",", 
         RowBox[{"ColorFunction", "->", "\"\<AvocadoColors\>\""}], ",", 
         RowBox[{"ColorFunctionScaling", "->", "True"}], ",", 
         RowBox[{"Frame", "->", "True"}], ",", 
         RowBox[{"FrameTicks", "->", "Automatic"}], ",", 
         RowBox[{"FrameLabel", "->", 
          RowBox[{"{", 
           
           RowBox[{"\"\<Destination Node (j)\>\"", 
            ",", "\"\<Origin Node (i)\>\""}], "}"}]}], ",", " ", 
         RowBox[{"AspectRatio", "->", "0.8"}], ",", 
         RowBox[{"PlotLabel", "->", 
          RowBox[{
          "Q1Title", 
           "[", "\"\<Anticipatory Markov Transition Matrix \\n(State \
Predictability)\>\"", "]"}]}], ",", 
         RowBox[{"(*", 
          RowBox[{
          "\:0e01\:0e32\:0e23\:0e1b\:0e23\:0e31\:0e1a\:0e41\:0e01\:0e49", " ", 
           RowBox[{"BarLegend", ":", 
            RowBox[{
            "\:0e41\:0e21\:0e1b\:0e2a\:0e40\:0e01\:0e25\:0e43\:0e2b\:0e49\
\:0e15\:0e23\:0e07\:0e01\:0e31\:0e1a\:0e02\:0e49\:0e2d\:0e21\:0e39\:0e25\:0e08\
\:0e23\:0e34\:0e07", " ", 
             "\:0e41\:0e25\:0e30\:0e1a\:0e31\:0e07\:0e04\:0e31\:0e1a", " ", 
             "Ticks", " ", "\:0e41\:0e04\:0e48", " ", 
             "\:0e0b\:0e49\:0e32\:0e22", " ", "\:0e01\:0e25\:0e32\:0e07", " ",
              "\:0e02\:0e27\:0e32"}]}]}], "*)"}], 
         RowBox[{"PlotLegends", "->", 
          RowBox[{"Placed", "[", 
           RowBox[{
            RowBox[{"BarLegend", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{"\"\<AvocadoColors\>\"", ",", 
                RowBox[{"{", 
                 RowBox[{"0", ",", "$maxProb"}], "}"}]}], "}"}], ",", 
              RowBox[{"LegendLabel", "->", "\"\<Transition Probability\>\""}],
               ",", 
              RowBox[{"LegendMarkerSize", "->", "300"}], ",", 
              RowBox[{"LegendLayout", "->", "\"\<Row\>\""}], ",", 
              RowBox[{"(*", 
               RowBox[{
                RowBox[{
                "\:0e1a\:0e31\:0e07\:0e04\:0e31\:0e1a\:0e41\:0e2a\:0e14\:0e07\
\:0e15\:0e31\:0e27\:0e40\:0e25\:0e02", " ", "3", " ", 
                 RowBox[{
                 "\:0e08\:0e38\:0e14\:0e40\:0e1e\:0e37\:0e48\:0e2d\:0e04\:0e27\
\:0e32\:0e21\:0e2a\:0e30\:0e2d\:0e32\:0e14\:0e15\:0e32", ":", "0"}]}], ",", 
                "\:0e04\:0e23\:0e36\:0e48\:0e07\:0e17\:0e32\:0e07", ",", 
                "\:0e41\:0e25\:0e30\:0e04\:0e48\:0e32\:0e2a\:0e39\:0e07\:0e2a\
\:0e38\:0e14"}], "*)"}], 
              RowBox[{"Ticks", "->", 
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"Round", "[", 
                  RowBox[{
                   RowBox[{"$maxProb", "/", "2"}], ",", "0.01"}], "]"}], ",", 
                 
                 RowBox[{"Round", "[", 
                  RowBox[{"$maxProb", ",", "0.01"}], "]"}]}], "}"}]}]}], 
             "]"}], ",", "Below"}], "]"}]}], ",", 
         RowBox[{"Epilog", "->", 
          RowBox[{"{", 
           RowBox[{"(*", 
            RowBox[{
            "\:0e15\:0e35\:0e40\:0e2a\:0e49\:0e19\:0e15\:0e32\:0e23\:0e32\
\:0e07\:0e43\:0e2b\:0e49\:0e14\:0e39\:0e40\:0e1b\:0e47\:0e19", " ", 
             RowBox[{"Mathematics", "/", "Matrix"}], " ", 
             "\:0e2a\:0e21\:0e1a\:0e39\:0e23\:0e13\:0e4c\:0e41\:0e1a\:0e1a"}],
             "*)"}], 
           RowBox[{
            RowBox[{"Directive", "[", 
             RowBox[{
              RowBox[{"GrayLevel", "[", "0.8", "]"}], ",", "Thin"}], "]"}], ",", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Line", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "k"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"$NumNodes", ",", "k"}], "}"}]}], "}"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "0", ",", "$NumNodes"}], "}"}]}], "]"}], ",", 
            RowBox[{"Table", "[", 
             RowBox[{
              RowBox[{"Line", "[", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"k", ",", "0"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"k", ",", "$NumNodes"}], "}"}]}], "}"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"k", ",", "0", ",", "$NumNodes"}], "}"}]}], "]"}]}], 
           "}"}]}], ",", 
         RowBox[{"BaseStyle", "->", "Automatic"}], ",", 
         RowBox[{"LabelStyle", "->", "$Q1BaseStyle"}], ",", 
         RowBox[{"FrameTicksStyle", "->", "$Q1BaseStyle"}], ",", 
         RowBox[{"ImageSize", "->", "Large"}], ",", 
         RowBox[{"AspectRatio", "->", "1"}]}], "]"}]}], ";"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"Print", "[", "plotMarkovMatrix", "]"}], ";"}]}]}]], "Input",
