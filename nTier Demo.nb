   RowBox[{
    RowBox[{"SeedRandom", "[", "999", "]"}], ";", "\[IndentingNewLine]", 
    RowBox[{"$LocalityData", "=", 
     RowBox[{"RandomVariate", "[", 
      RowBox[{
       RowBox[{"BinormalDistribution", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"350", ",", "80"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"100", ",", "40"}], "}"}], ",", "0.5"}], "]"}], ",", 
       "10000"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"plotLocality", "=", 
     RowBox[{"SmoothHistogram3D", "[", 
