      "\[IndentingNewLine]", 
      RowBox[{"$SmartTimeCum", "=", 
       RowBox[{"Accumulate", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Max", "[", 
           RowBox[{"#", ",", "0.001"}], "]"}], "&"}], "/@", 
         RowBox[{"(", 
          RowBox[{"$SmartLatency", "/", "1000"}], ")"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"$LegacyCO2", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "*", 
          RowBox[{"(", 
           RowBox[{"$PowerWatts", "/", "3600"}], ")"}], "*", "$CO2PerWh", "*",
           "1000"}], "&"}], "/@", "$LegacyTimeCum"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"$SmartCO2", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"#", "*", 
          RowBox[{"(", 
           RowBox[{"$PowerWatts", "/", "3600"}], ")"}], "*", "$CO2PerWh", "*",
           "1000"}], "&"}], "/@", "$SmartTimeCum"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
