Cell[BoxData[
 RowBox[{"\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"SECTION", ":", " ", 
    RowBox[{"AI", " ", "EPISTEMIC", " ", "UNCERTAINTY", " ", "PROOF", " ", 
     RowBox[{"(", 
      RowBox[{"NATIVE", " ", "v14", ".3"}], ")"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "===", "===", "===", "===", "===", "===", "===", "===", "===", "===", "===",
      "===", "===", "===", "===", "===", "===", "===", "==="}], "="}], "*)"}],
   "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Quiet", "[", 
     RowBox[{"(*", 
      RowBox[{
      "9.1", " ", 
       "\:0e08\:0e33\:0e25\:0e2d\:0e07\:0e1c\:0e25\:0e25\:0e31\:0e1e\:0e18\
\:0e4c\:0e08\:0e32\:0e01", " ", "Ensemble", " ", "ML", " ", 
       RowBox[{"(", 
        RowBox[{
        "\:0e2d\:0e49\:0e32\:0e07\:0e2d\:0e34\:0e07\:0e08\:0e32\:0e01\:0e40\
\:0e1b\:0e40\:0e1b\:0e2d\:0e23\:0e4c\:0e1b\:0e35", " ", "2024", " ", 
         "\:0e02\:0e2d\:0e07\:0e04\:0e38\:0e13"}], ")"}]}], "*)"}], 
     RowBox[{
      RowBox[{"SeedRandom", "[", "112", "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$NumTestMolecules", "=", "200"}], ";", "\[IndentingNewLine]", 
      RowBox[{"$ActualValues", "=", 
       RowBox[{"RandomReal", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"4.0", ",", "10.0"}], "}"}], ",", "$NumTestMolecules"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"$PredictedValues", "=", 
       RowBox[{"$ActualValues", "+", 
        RowBox[{"RandomVariate", "[", 
         RowBox[{
          RowBox[{"NormalDistribution", "[", 
           RowBox[{"0", ",", "0.3"}], "]"}], ",", "$NumTestMolecules"}], 
         "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"$ConsensusVariance", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Abs", "[", 
