     "\[IndentingNewLine]", 
    RowBox[{"NScale", "=", 
     RowBox[{"{", 
      RowBox[{
      "1000", ",", "10000", ",", "25000", ",", "50000", ",", "100000"}], 
      "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"generatePayload", "[", "id_", "]"}], ":=", 
     RowBox[{"<|", 
      RowBox[{
       RowBox[{"\"\<ID\>\"", "->", "id"}], ",", 
       RowBox[{"\"\<Domain\>\"", "->", 
        RowBox[{"RandomChoice", "[", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Logistics\>\"", ",", "\"\<IoMT\>\"", 
           ",", "\"\<SmartGrid\>\"", ",", "\"\<CNC\>\""}], "}"}], "]"}]}], ",", 
       RowBox[{"\"\<Value1\>\"", "->", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100"}], "}"}], "]"}]}], ",", 
       RowBox[{"\"\<Value2\>\"", "->", 
        RowBox[{"RandomReal", "[", 
         RowBox[{"{", 
          RowBox[{"0", ",", "100"}], "}"}], "]"}]}], ",", 
       RowBox[{"\"\<Status\>\"", "->", 
        RowBox[{"RandomChoice", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0.95", ",", "0.05"}], "}"}], "->", 
          RowBox[{"{", 
           RowBox[{"\"\<Authentic\>\"", ",", "\"\<Anomaly\>\""}], "}"}]}], 
         "]"}]}]}], "|>"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"RawDataList", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"generatePayload", "[", "i", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", 
         RowBox[{"Max", "[", "NScale", "]"}]}], "}"}]}], "]"}]}], ";", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"3.", " ", "Structural", " ", 
      RowBox[{"Translation", ":", 
       RowBox[{"O", 
        RowBox[{"(", "N", ")"}], " ", "List", " ", "vs", " ", "O", 
        RowBox[{"(", "1", ")"}], " ", "Semantic", " ", "Hash", " ", 
        "Association"}]}]}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"CloudDB", "=", "RawDataList"}], ";", "\[IndentingNewLine]", 
    RowBox[{"EdgeCache", "=", 
     RowBox[{"AssociationThread", "[", 
      RowBox[{
       RowBox[{"Range", "[", 
        RowBox[{"Max", "[", "NScale", "]"}], "]"}], "->", "RawDataList"}], 
      "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{"(*", 
     RowBox[{"4.", " ", "Asymptotic", " ", "Performance", " ", 
