       RowBox[{"Final", " ", "Publication", " ", "Metrics"}]}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"FinalCloudLat", "=", 
     RowBox[{"Round", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Last", "[", "CloudLatency", "]"}], "[", 
