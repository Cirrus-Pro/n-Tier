    RowBox[{"Q1Font", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<FontFamily\>\"", "->", "\"\<Times New Roman\>\""}], ",", 
       RowBox[{"\"\<FontSize\>\"", "->", "14"}]}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Q1Title", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\"\<FontFamily\>\"", "->", "\"\<Times New Roman\>\""}], ",", 
       RowBox[{"\"\<FontSize\>\"", "->", "14"}], ",", 
       RowBox[{"\"\<FontWeight\>\"", "->", "\"\<Bold\>\""}]}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"ColCloud", "=", 
     RowBox[{"Darker", "[", 
      RowBox[{"Red", ",", "0.2"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"ColEdge", "=", 
     RowBox[{"Darker", "[", 
      RowBox[{"Green", ",", "0.2"}], "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Print", "[", 
     RowBox[{"Style", "[", 
      RowBox[{"\"\<\\n[SYSTEM INITIALIZATION] Commencing Multi-Domain \
