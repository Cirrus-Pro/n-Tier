        RowBox[{"Max", "[", "NScale", "]"}], "]"}], ",", "100"}], "]"}]}], ";",
     "\[IndentingNewLine]", 
    RowBox[{"CloudLatency", "=", 
     RowBox[{"{", "}"}]}], ";", 
    RowBox[{"EdgeLatency", "=", 
     RowBox[{"{", "}"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Do", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"subsetN", "=", 
        RowBox[{"NScale", "[", 
         RowBox[{"[", "idx", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"CloudDBSubset", "=", 
        RowBox[{"Take", "[", 
         RowBox[{"CloudDB", ",", "subsetN"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"timeCloud", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"AbsoluteTiming", "[", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{"SelectFirst", "[", 
               RowBox[{"CloudDBSubset", ",", 
                RowBox[{
                 RowBox[{
                  RowBox[{"#", "[", "\"\<ID\>\"", "]"}], "==", "tid"}], 
                 "&"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"tid", ",", "TargetIDs"}], "}"}]}], "]"}], "]"}], "[", 
           
           RowBox[{"[", "1", "]"}], "]"}], "/", "100.0"}], "*", 
         RowBox[{"10", "^", "6"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"timeEdge", "=", 
        RowBox[{
         RowBox[{
          RowBox[{
           RowBox[{"AbsoluteTiming", "[", 
            RowBox[{"Do", "[", 
             RowBox[{
              RowBox[{"Lookup", "[", 
               RowBox[{"EdgeCache", ",", "tid"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"tid", ",", "TargetIDs"}], "}"}]}], "]"}], "]"}], "[", 
           
           RowBox[{"[", "1", "]"}], "]"}], "/", "100.0"}], "*", 
         RowBox[{"10", "^", "6"}]}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"CloudLatency", ",", 
         RowBox[{"{", 
          RowBox[{"subsetN", ",", "timeCloud"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"AppendTo", "[", 
        RowBox[{"EdgeLatency", ",", 
         RowBox[{"{", 
          RowBox[{"subsetN", ",", "timeEdge"}], "}"}]}], "]"}], ";"}], ",", 
