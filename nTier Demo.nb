Cell[BoxData[{
 RowBox[{
  RowBox[{"Quiet", "[", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"8.2", " ", "Topological", " ", "Data", " ", "Locality", " ", 
      RowBox[{"(", 
       RowBox[{"3", "D", " ", "Mountain", " ", "Upgrade"}], ")"}]}], "-", 
